# bookrack configuration. Copy this file to `.env` and fill it in.
# `.env` is gitignored; this template is committed with placeholders.

# Absolute path to the bookrack data root. It holds ALL book data:
# source files, the opaque intake store, the databases, and the vector
# store. Keep it OUTSIDE the project workspace so book content — real
# titles included — never sits next to the source code.
BOOKRACK_DATA_DIR=

# Path to a TOML library registry, mapping short names to data roots.
# Optional; only `--library <name>` needs it. With it set, `bookrack
# --library test ...` selects a root without re-exporting the variable
# above. The data root is chosen by precedence: `--data-dir`, then
# `--library`, then BOOKRACK_DATA_DIR, then the registry's `default`.
# An entry is either a metadata-bearing table or a legacy bare path;
# both are accepted, and any write rewrites the file into the table
# form. File shape:
#   default = "prod"
#   [libraries.prod]
#   data_dir = "/abs/path/to/prod-root"
#   kind     = "prod"                    # prod | test | scratch
#   # Legacy bare-path entries stay readable:
#   # test = "/abs/path/to/test-root"
BOOKRACK_REGISTRY=

# Ollama HTTP endpoint for embeddings. Optional; the value below is the
# default used when this is unset.
BOOKRACK_OLLAMA_URL=http://localhost:11434

# Operational embedding and search knobs. All optional; the values below
# are the defaults. These are operational only — they never change the
# identity of already-ingested content. Content-identity parameters
# (chunk length, overlap, grouping) are NOT exposed here: they are frozen
# with CHUNK_VERSION, so changing them forces a re-derivation.

# The embed model is not an environment knob. It is the semantic
# identity of a library's vectors -- which model wrote them, and so which
# model can read them -- so the library's index profile declares it:
#   bookrack libraries config <name> index_profile=<profile>
# `bookrack index-profile current` shows what resolves. Changing an
# ingested library's model is a separate job, since its vectors were
# written by the old one: `bookrack libraries fork` (rebuild a clone),
# `bookrack index-profile apply` (reconcile in place), or
# `bookrack vectors reset` (destructive, in place).

# Batching budgets: how an embed run is paced, not what it produces.
BOOKRACK_EMBED_BATCH_CHAR_BUDGET=8000
BOOKRACK_EMBED_BATCH_MAX_CHUNKS=64
BOOKRACK_EMBED_BATCH_MIN_CHAR_BUDGET=500
# Seconds between embed-progress log lines during a long ingest.
BOOKRACK_EMBED_PROGRESS_INTERVAL_SECS=5
# The `[search]` table in `<data_root>/config.toml` (`search.top_k`,
# `search.weak_threshold` via `bookrack libraries config`) is the
# persistent equivalent of the two knobs below; a set env var still
# overrides the file.
BOOKRACK_SEARCH_TOP_K=5
# Distance above which a returned passage is graded a weak match.
BOOKRACK_SEARCH_WEAK_THRESHOLD=0.5

# Per-query ANN override knobs, normally left unset — they tune retrieval
# breadth without re-embedding. `BOOKRACK_VECTORS_BYPASS_ANN` (`1` /
# `true` / `yes`) forces an exhaustive brute-force scan;
# `BOOKRACK_VECTORS_NPROBES` and `BOOKRACK_VECTORS_REFINE_FACTOR`
# (integers) raise the IVF probe breadth and refine depth. Unset means
# the built index's own settings apply.
#BOOKRACK_VECTORS_BYPASS_ANN=
#BOOKRACK_VECTORS_NPROBES=
#BOOKRACK_VECTORS_REFINE_FACTOR=

# Directory holding the PDFium dynamic library (`libpdfium.dylib` /
# `libpdfium.so` / `pdfium.dll`) the PDF adapter binds at runtime.
# Optional, and authoritative when set: no fallback is tried, so a typo
# surfaces as a miss. When unset, the adapter searches the running
# executable's own directory (the release-archive layout), then the
# per-user managed directory that `bookrack doctor --install-pdfium`
# populates with the pinned build. Pin details:
# `crates/extract/PDFIUM_VERSION.md`.
BOOKRACK_PDFIUM_LIB=

# Operator-run rerank server. Optional; overrides `reranker.url` in the
# per-root `config.toml`. When either is set, the daemon does not spawn
# its own llama-server for a reranker-enabled profile: it probes this
# endpoint once at startup and refuses to start if it is not ready.
# When both are unset, the daemon supervises the pinned llama-server
# found through the chain below.
BOOKRACK_RERANKER_URL=

# Path of the `llama-server` executable the reranker backend spawns.
# Optional, and authoritative when set: no fallback is tried and no
# checksum applies, so a typo surfaces as a miss. When unset, the
# search covers `llama-server` beside the running executable (the
# release-archive layout), then the per-user managed directory that
# `bookrack doctor --install-reranker` populates with the pinned
# build. Pin details: `crates/config/LLAMA_SERVER_VERSION.md`.
BOOKRACK_LLAMA_SERVER_BIN=

# Path of the reranker GGUF model file. Optional, and authoritative
# when set: it wins for every model tag, no fallback is tried, and no
# checksum applies. When unset, the per-user managed directory that
# `bookrack doctor --install-reranker` populates with the pinned
# conversion is searched. Pin details:
# `crates/config/LLAMA_SERVER_VERSION.md`.
BOOKRACK_RERANKER_MODEL=

# Directory database backups are written to before a schema migration.
# Optional; defaults to `backup/` under the data root when unset.
BOOKRACK_BACKUP_DIR=

# Address the MCP server binds. Optional; the value below is the default.
# Loopback only — the server is a local query daemon. Connect an MCP client
# (e.g. Claude Code) as an HTTP server at `http://<addr>/mcp`.
BOOKRACK_MCP_ADDR=127.0.0.1:8765

# Directory for daemon-scoped state that spans libraries: the ingest
# queue snapshot (`queue.json`). Machine-scoped, not per-library — one
# daemon process owns one of these regardless of how many libraries it
# serves. Optional; when unset the binary falls back to the
# platform-conventional per-user data directory
# (`~/Library/Application Support/bookrack/daemon` on macOS,
# `$XDG_DATA_HOME/bookrack/daemon` on Linux,
# `%APPDATA%\bookrack\daemon` on Windows). A queue snapshot left under
# a data root by an older binary is migrated over on daemon start.
BOOKRACK_DAEMON_STATE_DIR=

# Directory for session-level runtime state: the single-instance lock
# file the interactive REPL holds for its lifetime, and the line-editor
# history file. Machine-scoped, not per-library. Optional; when unset
# the binary falls back to the platform-conventional cache directory —
# `$XDG_RUNTIME_DIR/bookrack` (with `$XDG_CACHE_HOME` then `$HOME/.cache`
# as fallbacks) on Linux, `$HOME/Library/Caches/bookrack` on macOS, and
# `%LOCALAPPDATA%\bookrack` on Windows.
BOOKRACK_RUNTIME_DIR=

# Log verbosity. Optional; the value below is the default. Accepts an
# EnvFilter directive, e.g. `info`, `debug`, or `bookrack_ingest=debug,info`.
# The default keeps bookrack's crates at `info` while pinning the noisy
# vector-store dependencies to `warn`. The console layer writes
# human-readable lines to stderr; a rolling JSON file is written under the
# data root's `logs/` directory.
BOOKRACK_LOG=info,lance=warn,lance_namespace_impls=warn,lance_table=warn,lance_index=error,datafusion=warn,rusqlite_migration=warn

# Console-layer (stderr) verbosity, independent of the JSON file log
# above. Optional; defaults to `error` so one-shot commands stay quiet
# while the full-detail stream still lands in the `logs/` file. Accepts
# the same EnvFilter directive grammar as BOOKRACK_LOG.
BOOKRACK_LOG_CONSOLE=error
