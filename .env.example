# bookrack configuration. Copy this file to `.env` and fill it in.
# `.env` is gitignored; this template is committed with placeholders.

# Absolute path to the bookrack data root. It holds ALL book data:
# source files, the opaque intake store, the databases, and the vector
# store. Keep it OUTSIDE the project workspace so book content — real
# titles included — never sits next to the source code.
BOOKRACK_DATA_DIR=

# Path to a TOML library registry, mapping short names to data roots.
# Optional; only `--library <name>` needs it. With it set, `bookrack
# --library test ...` selects a root without re-exporting the variable
# above. The data root is chosen by precedence: `--data-dir`, then
# `--library`, then BOOKRACK_DATA_DIR, then the registry's `default`.
# File shape:
#   default = "prod"
#   [libraries]
#   prod = "/abs/path/to/prod-root"
#   test = "/abs/path/to/test-root"
BOOKRACK_REGISTRY=

# Ollama HTTP endpoint for embeddings. Optional; the value below is the
# default used when this is unset.
BOOKRACK_OLLAMA_URL=http://localhost:11434

# Operational embedding and search knobs. All optional; the values below
# are the defaults. These are operational only — they never change the
# identity of already-ingested content. Content-identity parameters
# (chunk length, overlap, grouping) are NOT exposed here: they are frozen
# with CHUNK_VERSION, so changing them forces a re-derivation.
BOOKRACK_EMBED_MODEL=qwen3-embedding:0.6b
BOOKRACK_EMBED_BATCH_CHAR_BUDGET=8000
BOOKRACK_EMBED_BATCH_MAX_CHUNKS=64
BOOKRACK_EMBED_BATCH_MIN_CHAR_BUDGET=500
BOOKRACK_SEARCH_TOP_K=5

# Directory database backups are written to before a schema migration.
# Optional; defaults to `backup/` under the data root when unset.
BOOKRACK_BACKUP_DIR=

# Address the MCP server binds. Optional; the value below is the default.
# Loopback only — the server is a local query daemon. Connect an MCP client
# (e.g. Claude Code) as an HTTP server at `http://<addr>/mcp`.
BOOKRACK_MCP_ADDR=127.0.0.1:8765

# Directory for session-level runtime state: the single-instance lock
# file the interactive REPL holds for its lifetime, and the line-editor
# history file. Machine-scoped, not per-library. Optional; when unset
# the binary falls back to the platform-conventional cache directory —
# `$XDG_RUNTIME_DIR/bookrack` (with `$XDG_CACHE_HOME` then `$HOME/.cache`
# as fallbacks) on Linux, `$HOME/Library/Caches/bookrack` on macOS, and
# `%LOCALAPPDATA%\bookrack` on Windows.
BOOKRACK_RUNTIME_DIR=

# Log verbosity. Optional; the value below is the default. Accepts an
# EnvFilter directive, e.g. `info`, `debug`, or `bookrack_ingest=debug,info`.
# The default keeps bookrack's crates at `info` while pinning the noisy
# vector-store dependencies to `warn`. The console layer writes
# human-readable lines to stderr; a rolling JSON file is written under the
# data root's `logs/` directory.
BOOKRACK_LOG=info,lance=warn,lance_namespace_impls=warn,lance_table=warn,lance_index=error,datafusion=warn
