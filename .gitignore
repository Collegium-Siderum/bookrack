# Build output
/target/

# Private library data — never commit
/data/
/books/
/index/
*.lance/
*.sqlite
*.sqlite-*
*.db
# Committed test fixtures stay tracked despite the *.db blanket.
!crates/*/tests/fixtures/**/*.db

# Secrets / local config
.env
.env.*
!.env.example
.claude/
# `.cargo/config.toml` is committed (routes ts-rs binding output to
# `crates/app/web/src/generated/` via `TS_RS_EXPORT_DIR`). Everything
# else under `.cargo/` is machine-specific state — toolchain cache,
# the `config.local.toml` that the tracked file `include`s for local
# overrides such as `[build] target-dir`, etc.
/.cargo/*
!/.cargo/config.toml
/.serena/

# Agent instructions — local working file, deliberately not committed
/CLAUDE.md

# Leak-check denylist — holds private literals, must stay local
/scripts/leak-denylist.txt

# Exploratory spikes — contain hardcoded local paths
/spikes/

# Local scratch space — native binaries and throwaway working files
/scratch/

# Auto-generated by ts-rs in cargo test (PR-2 onward).
crates/app/web/src/generated/*.ts

# OS / editor cruft
.DS_Store
Thumbs.db

# Drafts
/drafts
/drafts-py